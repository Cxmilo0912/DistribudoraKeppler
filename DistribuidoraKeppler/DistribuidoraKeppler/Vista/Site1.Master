<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site1.master.cs" Inherits="DistribuidoraKeppler.Vista.Site1" %>

<!DOCTYPE html>
<html lang="es">
<head runat="server">
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kepler - Distribución Inteligente</title>

    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Google Material Symbols (Outlined) -->
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Hojas de estilos del ContentPlaceHolder (Hijo) -->
    <asp:ContentPlaceHolder ID="head" runat="server"></asp:ContentPlaceHolder>

    <script type="text/javascript">
        const idUsuarioGlobal = '<%= Session["IdCliente"] != null ? Session["IdCliente"].ToString() : "0" %>';
        if (idUsuarioGlobal !== "0") {
            localStorage.setItem("usuarioActivoId", idUsuarioGlobal);
        }
    </script>
</head>

<body class="bg-slate-50 text-slate-800 font-sans antialiased">
    <form id="form1" runat="server" class="min-h-screen flex">

        <!-- =========================================================================
             SIDEBAR PREMIUM: MODO OSCURO PROFUNDO (DEGRADADO COHERENTE)
             ========================================================================= -->
