<%@ Master Language="C#" AutoEventWireup="true" CodeBehind="Site1.master.cs" Inherits="DistribuidoraKeppler.Vista.Site1" %>

<!DOCTYPE html>
<html lang="es">
<head runat="server">
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kepler - Distribución Inteligente</title>

    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <asp:ContentPlaceHolder ID="head" runat="server"></asp:ContentPlaceHolder>

    <script type="text/javascript">
        const idUsuarioGlobal = '<%= Session["IdCliente"] != null ? Session["IdCliente"].ToString() : "0" %>';
        if (idUsuarioGlobal !== "0") {
            localStorage.setItem("usuarioActivoId", idUsuarioGlobal);
        }
    </script>
</head>

<body class="bg-slate-50 text-slate-800 font-sans antialiased">
    <form id="form1" runat="server" class="min-h-screen flex">

        <aside class="fixed left-0 top-0 h-full w-64 bg-gradient-to-b from-[#0f143c] to-[#090d26] text-slate-300 flex flex-col justify-between border-r border-white/[0.06] shadow-2xl z-50">

