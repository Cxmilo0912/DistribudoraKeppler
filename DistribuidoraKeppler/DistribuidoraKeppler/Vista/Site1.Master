        </aside>

        <main class="flex-1 ml-64 p-8 min-h-screen">
            <asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server" />
        </main>

    </form>

    <script type="text/javascript">
        document.addEventListener("DOMContentLoaded", function () {
            const urlActual = window.location.pathname.split("/").pop().toLowerCase();
            const enlaces = document.querySelectorAll("#sidebarMenu a");

            enlaces.forEach(enlace => {
                const href = enlace.getAttribute("href");

                if (href) {
                    const paginaEnlace = href.split("/").pop().toLowerCase();

                    if (urlActual === paginaEnlace) {
                        // Limpiamos los estados base
                        enlace.classList.remove("text-slate-300", "hover:bg-white/[0.05]", "hover:text-white", "border-transparent");

                        // Asignamos las clases activas manteniendo el border-l-4 intacto para evitar saltos bruscos
                        enlace.classList.add(
                            "bg-gradient-to-r",
                            "from-blue-600/20",
                            "to-blue-600/5",
                            "text-white",
                            "font-semibold",
                            "border-l-4",
                            "border-blue-500"
                        );

                        const icono = enlace.querySelector(".material-symbols-outlined");
                        if (icono) {
                            icono.classList.remove("opacity-70");
                            icono.classList.add("text-blue-400", "opacity-100");
                        }
                    }
                }
            });
        });
    </script>
</body>
</html>
