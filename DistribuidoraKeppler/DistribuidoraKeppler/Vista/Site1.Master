                            </asp:HyperLink>

                            <asp:HyperLink runat="server" NavigateUrl="#"
                                CssClass="group flex items-center gap-3 px-4 py-2.5 rounded-xl text-sm font-medium transition-all duration-200 hover:bg-slate-800/50 hover:text-white border-l-4 border-transparent">
                                <span class="material-symbols-outlined !text-[20px] opacity-70 group-hover:opacity-100 transition-opacity">shopping_cart</span> Pedidos
                            </asp:HyperLink>

