            <!-- CARD DE USUARIO INFERIOR -->
            <div class="p-4 border-t border-slate-800/60 bg-[#000814]/40 backdrop-blur-sm flex-shrink-0">
                <div class="flex items-center gap-3 bg-slate-800/40 p-3 rounded-xl border border-slate-700/30">
                    <img src="https://i.pravatar.cc/40?img=33" alt="Avatar" class="w-9 h-9 rounded-full ring-2 ring-blue-500/30 object-cover" />
                    <div class="min-w-0 flex-1">
                        <p class="text-xs font-semibold text-white truncate">Operador Activo</p>
                        <asp:Label ID="lblRol" runat="server" CssClass="text-[10px] font-bold text-blue-400 block uppercase tracking-wider truncate" Text="Rol Sistema"></asp:Label>
                    </div>
                </div>

                <!-- BOTÓN CERRAR SESIÓN -->
                <asp:LinkButton ID="btnCerrarSesión" runat="server"
                    CssClass="mt-3 w-full bg-gradient-to-r from-red-600 to-rose-600 hover:from-red-500 hover:to-rose-500 text-white font-semibold text-xs py-2.5 rounded-xl text-center flex items-center justify-center gap-2 transition-all duration-200 shadow-lg shadow-red-950/20"
                    OnClick="btnCerrarSesión_Click">
                    <span class="material-symbols-outlined !text-[16px]">logout</span>
                    <span>Cerrar Sesión</span>
                </asp:LinkButton>
            </div>

        </aside>

        <!-- =========================================================================
             LIENZO DE CONTENIDO PRINCIPAL (MAIN CANVAS)
             ========================================================================= -->
        <main class="flex-1 ml-64 p-8 min-h-screen">
            <asp:ContentPlaceHolder ID="ContentPlaceHolder1" runat="server" />
        </main>

    </form>

    <!-- JS PARA GESTIÓN DE ENLACES ACTIVOS -->
    <script type="text/javascript">
        document.addEventListener("DOMContentLoaded", function () {
            const urlActual = window.location.pathname.split("/").pop().toLowerCase();
            const enlaces = document.querySelectorAll("#sidebarMenu a");

            enlaces.forEach(enlace => {
                const href = enlace.getAttribute("href");

                if (href) {
                    const paginaEnlace = href.split("/").pop().toLowerCase();

                    if (urlActual === paginaEnlace) {
                        enlace.classList.remove("text-slate-300", "hover:bg-slate-800/50", "hover:text-white", "border-transparent");

                        enlace.classList.add(
                            "bg-gradient-to-r",
                            "from-blue-600",
                            "to-blue-700",
                            "text-white",
                            "font-semibold",
                            "shadow-lg",
                            "shadow-blue-600/10",
                            "border-blue-400" // Ahora solo cambia el color, el grosor ya existía
                        );

                        const icono = enlace.querySelector(".material-symbols-outlined");
                        if (icono) {
                            icono.classList.remove("opacity-70");
                            icono.classList.add("text-white", "opacity-100");
                        }
                    }
                }
            });
        });
    </script>
</body>
</html>
