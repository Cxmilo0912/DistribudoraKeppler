                <div class="p-4 border-t border-white/[0.06] bg-black/10 space-y-3 flex-shrink-0">
                    <div class="flex items-center gap-3 bg-white/[0.03] p-3 rounded-xl border border-white/[0.06]">
                        <img src="https://i.pravatar.cc/40?img=33" alt="Avatar" class="w-9 h-9 rounded-full ring-2 ring-blue-500/30 object-cover" />
                        <div class="min-w-0 flex-1">
                            <p class="text-xs font-semibold text-white truncate">Operador Activo</p>
                            <asp:Label ID="lblRol" runat="server" CssClass="text-[10px] font-bold text-blue-400 block uppercase tracking-wider truncate" Text="Rol Sistema"></asp:Label>
                        </div>
                    </div>

                    <asp:LinkButton ID="btnCerrarSesion" runat="server"
                        CssClass="w-full bg-gradient-to-r from-red-600 to-rose-600 hover:from-red-500 hover:to-rose-500 text-white font-semibold text-xs py-2.5 rounded-xl text-center flex items-center justify-center gap-2 transition-all duration-200 shadow-lg shadow-red-950/20"
                        OnClick="btnCerrarSesion_Click">
                        <span class="material-symbols-outlined !text-[16px]">logout</span>
                        <span>Cerrar Sesión</span>
                    </asp:LinkButton>
